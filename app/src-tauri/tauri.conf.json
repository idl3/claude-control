{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Control",
  "version": "0.0.1",
  "identifier": "com.ernest.claude-control.spike",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Control",
        "width": 1280,
        "height": 860,
        "minWidth": 480,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
