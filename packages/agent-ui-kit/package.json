{
  "name": "@idl3/agent-ui-kit",
  "version": "0.1.0",
  "description": "Headless agent-interaction UI renderers shared between claude-control (source of truth) and external hosts. Data + callbacks arrive via props; theming via --auk-* CSS custom properties. No data, auth, or tenancy inside.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idl3/claude-control.git",
    "directory": "packages/agent-ui-kit"
  },
  "homepage": "https://github.com/idl3/claude-control/tree/main/packages/agent-ui-kit#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsc && cp src/styles.css dist/styles.css",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
