# Match BOTH a node_modules directory AND a `node_modules` symlink (worktrees
# symlink it to the main checkout). A trailing-slash pattern matches dirs only,
# so a symlink slipped past it and got committed once — keep these slash-less.
node_modules
web/node_modules
web/dist/
outputs/
*.log
.DS_Store
.env
.env.*
*.tgz
.envrc
scratch/
web/scratch/
packages/agent-ui-kit/dist/
